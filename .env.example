# Postgres (Neon) — get from neon.tech → Connection Details
DATABASE_URI=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Generate a long random string: openssl rand -base64 32
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Public site URL (used by Payload + cookies)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Cloudflare R2 (S3-compatible) — leave blank for now if not yet set up
S3_BUCKET=storeit-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
